#!/usr/bin/env bash
# chezmoi modify_ script. chezmoi pipes the current ~/.bashrc on stdin;
# whatever this prints to stdout becomes the new content. Strips any
# existing managed block and appends a fresh one, so re-running is a no-op.

set -eufo pipefail

MARKER_START='# >>> dotfiles shared shell >>>'
MARKER_END='# <<< dotfiles shared shell <<<'

# Echo stdin minus any prior managed block. Buffer blank lines so a trailing
# run of blanks gets dropped (otherwise each apply adds another blank line
# before the marker and idempotency breaks).
awk -v s="$MARKER_START" -v e="$MARKER_END" '
  $0 == s { skip = 1; pending = ""; next }
  $0 == e { skip = 0; next }
  skip    { next }
  /^$/    { pending = pending "\n"; next }
  { printf "%s%s\n", pending, $0; pending = "" }
'

cat <<EOF

$MARKER_START
# Managed by chezmoi. Do not edit! Changes will be overwritten!
HISTCONTROL=ignorespace
HISTIGNORE='cd *:kill *:g *:l:ls:ll:la:pwd:exit:exit!'
[ -r "\$HOME/.config/shell/env.sh"       ] && . "\$HOME/.config/shell/env.sh"
[ -r "\$HOME/.config/shell/aliases.sh"   ] && . "\$HOME/.config/shell/aliases.sh"
[ -r "\$HOME/.config/shell/functions.sh" ] && . "\$HOME/.config/shell/functions.sh"
$MARKER_END
EOF
