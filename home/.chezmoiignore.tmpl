{{- /*
  Files listed here are NOT applied to the target (the source still keeps them).
  Two gates:
    - per-role: on a clawbot ({{ "{{ if .clawbot }}" }}) drop the whole personal /
      human-desktop layer, regardless of OS.
    - per-OS: drop the other OS's scripts / externals / desktop files.
*/ -}}

{{- /* fish is parked for now on every machine. */ -}}
.config/fish

{{ if .clawbot -}}
{{- /* ── clawbot: skip the personal / human-desktop layer ─────────────────── */ -}}
.actrc
.cdk.json
.config/alacritty
.config/aws-sso
.config/cloc
.config/ghostty
.config/homebrew
.config/karabiner
.config/kubetail
.config/ohmyzsh
.config/shell/aliases.sh
.config/wezterm
.config/zsh/.fzf-tab.zsh
.config/zsh/.fzf.zsh
.config/zsh/.p10k.zsh
.config/zsh/.zshrc
.docker
.finch
.fxrc.js
.gradle
.hammerspoon
.local/bin/aws-sso-auto
.yarnrc.yml
Library/**
{{ end -}}

{{ if not .clawbot -}}
{{- /* ── human only: clawbot-specific seeds (drop on a human box) ──────────────
       gh hosts.yml carries a FAKE placeholder token for gateway injection; a human
       box must keep its own real gh auth, so never apply the placeholder there.
       app-log-investigation is an agent/clawbot skill (queries CloudWatch via the
       gateway-configured AWS credentials); both runtimes' symlinks resolve to the
       same private-overlay source, and its shared aws-architecture.md reference
       (surfaced at ~/.config/ai/references/) serves only that skill, so it's gated too.
       NB: keep these as consecutive bare lines — an inline {{ "{{- … -}}" }}
       comment between them trims the newlines and glues two patterns into one. */ -}}
.config/gh/hosts.yml
.claude/skills/app-log-investigation
.hermes/skills/devops/app-log-investigation
.config/ai/references/aws-architecture.md
{{ end -}}

{{ if ne .chezmoi.os "darwin" -}}
{{- /* ── not macOS ─────────────────────────────────────────────────────────── */ -}}
.chezmoiexternals/darwin.*
.chezmoiscripts/darwin/**
.config/homebrew
.config/karabiner
.hammerspoon
Library/**
{{ end -}}

{{ if ne .chezmoi.os "linux" -}}
{{- /* ── not Linux ─────────────────────────────────────────────────────────── */ -}}
.chezmoiexternals/linux.*
.chezmoiscripts/linux/**
.hushlogin
.local/bin/nvim
.local/share/fonts
{{ end -}}
