{{- /* Deliver the app-log-investigation skill onto Claude's user-skill load path
       (~/.claude/skills/). Unlike aws-sso (which lives in the public repo-root ai/),
       this skill AND its references are PRIVATE, so the source is the private overlay
       — same model as opencode's AGENTS.md symlink. sourceDir is ~/.dotfiles/home,
       so ".." is the repo root; the overlay is its sibling under private/. The stat
       guard makes the link dangle silently when the overlay is absent, so the public
       tree always stands alone. The same private dir feeds Hermes'
       ~/.hermes/skills/devops/ symlink — one copy, no drift. Robot-only: gated to
       clawbots in .chezmoiignore. */ -}}
{{- $src := joinPath .chezmoi.sourceDir ".." "private" "home" "config" "ai" "skills" "app-log-investigation" -}}
{{- if stat $src }}{{ $src }}{{ end -}}
