#!/usr/bin/env bash
# chezmoi modify_ script for ~/.profile (login shells, incl. non-interactive
# `sh`). chezmoi pipes the current file on stdin; our stdout becomes the new one.
# Preserves existing content; ensures one managed block that wires PATH for login
# shells and pulls in ~/.bashrc under bash.
set -eufo pipefail

MARKER_START='# >>> chezmoi-dotfiles (managed) >>>'
MARKER_END='# <<< chezmoi-dotfiles (managed) <<<'

awk -v s="$MARKER_START" -v e="$MARKER_END" '
  $0 == s { skip = 1; pending = ""; next }
  $0 == e { skip = 0; next }
  skip    { next }
  /^$/    { pending = pending "\n"; next }
  { printf "%s%s\n", pending, $0; pending = "" }
'

cat <<EOF

$MARKER_START
# Managed by chezmoi. Do not edit! Changes will be overwritten!
[ -r "\$HOME/.config/shell/env.sh" ] && . "\$HOME/.config/shell/env.sh"
if [ -n "\$BASH_VERSION" ] && [ -r "\$HOME/.bashrc" ]; then . "\$HOME/.bashrc"; fi
$MARKER_END
EOF
