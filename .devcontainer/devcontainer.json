{
	"name": "Ubuntu",
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	// "features": {},
	"postCreateCommand": "git clone https://github.com/akefirad/dotfiles.git ~/.dotfiles && ~/.dotfiles/install.sh",
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh"
			}
		}
	},
	"containerEnv": {
		"DEVCONTAINER": "1",
		"ZDOTDIR": "/home/vscode/.config/zsh"
	}
	// "remoteUser": "root"
}
