.DS_Store
**/.DS_Store

test/.cache/

# skill-creator eval run artifacts (benchmark/grading/outputs/review.html).
# Throwaway; the skill itself lives in ai/skills/<name>/.
*-workspace/

# Transient git worktrees created by background agents (keep .claude/skills/).
/.claude/worktrees/

# Private overlay: per-machine sibling clone, set up by install.sh. Not
# tracked here so forkers can point at their own private repo (or none)
# without conflicts on every upstream pull.
/private/
/private/clawtilla/private/